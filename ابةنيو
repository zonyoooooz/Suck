local reachDistance = 50

local screenGui = Instance.new("ScreenGui")
screenGui.Parent = game.Players.LocalPlayer.PlayerGui

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 200, 0, 150)
frame.Position = UDim2.new(0.5, -100, 0.5, -75)
frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
frame.Parent = screenGui

local reachSlider = Instance.new("Slider")
reachSlider.Min = 10
reachSlider.Max = 100
reachSlider.Size = UDim2.new(0, 180, 0, 30)
reachSlider.Position = UDim2.new(0, 10, 0, 40)
reachSlider.Parent = frame
reachSlider.Value = reachDistance

local reachLabel = Instance.new("TextLabel")
reachLabel.Text = "مدى Reach: " .. reachSlider.Value
reachLabel.Size = UDim2.new(0, 180, 0, 30)
reachLabel.Position = UDim2.new(0, 10, 0, 10)
reachLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
reachLabel.BackgroundTransparency = 1
reachLabel.Parent = frame

reachSlider.Changed:Connect(function()
    reachLabel.Text = "مدى Reach: " .. reachSlider.Value
    reachDistance = reachSlider.Value
end)

local function applyReachHack()
    local character = game.Players.LocalPlayer.Character
    if character then
        game:GetService("ReplicatedStorage").Events.ReachEvent:FireServer(reachDistance)
    end
end

while true do
    applyReachHack()
    wait(0.1)
end
