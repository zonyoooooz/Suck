local ScreenGui = Instance.new("ScreenGui")
local MainFrame = Instance.new("Frame")
local Title = Instance.new("TextLabel")
local PingLabel = Instance.new("TextLabel")
local IncreaseBtn = Instance.new("TextButton")
local DecreaseBtn = Instance.new("TextButton")

local fakePingValue = 100

ScreenGui.Parent = game.CoreGui
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
MainFrame.Position = UDim2.new(0.8, 0, 0.2, 0)
MainFrame.Size = UDim2.new(0, 180, 0, 130)
MainFrame.Active = true
MainFrame.Draggable = true

Title.Parent = MainFrame
Title.Size = UDim2.new(1, 0, 0, 30)
Title.Text = "ZERO PING CONTROL"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.BackgroundColor3 = Color3.fromRGB(35, 35, 35)

PingLabel.Parent = MainFrame
PingLabel.Position = UDim2.new(0, 0, 0.3, 0)
PingLabel.Size = UDim2.new(1, 0, 0, 30)
PingLabel.Text = "Fake Ping: " .. fakePingValue .. "ms"
PingLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
PingLabel.BackgroundTransparency = 1

IncreaseBtn.Parent = MainFrame
IncreaseBtn.Position = UDim2.new(0.1, 0, 0.65, 0)
IncreaseBtn.Size = UDim2.new(0.35, 0, 0.25, 0)
IncreaseBtn.Text = "+"
IncreaseBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
IncreaseBtn.TextColor3 = Color3.fromRGB(255, 255, 255)

DecreaseBtn.Parent = MainFrame
DecreaseBtn.Position = UDim2.new(0.55, 0, 0.65, 0)
DecreaseBtn.Size = UDim2.new(0.35, 0, 0.25, 0)
DecreaseBtn.Text = "-"
DecreaseBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
DecreaseBtn.TextColor3 = Color3.fromRGB(255, 255, 255)

local function updateDisplay()
    PingLabel.Text = "Fake Ping: " .. fakePingValue .. "ms"
end

IncreaseBtn.MouseButton1Click:Connect(function()
    fakePingValue = fakePingValue + 50
    updateDisplay()
end)

DecreaseBtn.MouseButton1Click:Connect(function()
    if fakePingValue > 0 then
        fakePingValue = fakePingValue - 50
        updateDisplay()
    end
end)

game:GetService("RunService").Heartbeat:Connect(function()
    if fakePingValue > 100 then
        local delayTime = fakePingValue / 1000
        local startTime = tick()
        repeat until tick() - startTime >= delayTime
    end
end)
