local ScreenGui = Instance.new("ScreenGui")
local MainFrame = Instance.new("Frame")
local Title = Instance.new("TextLabel")
local ReachLabel = Instance.new("TextLabel")
local IncreaseBtn = Instance.new("TextButton")
local DecreaseBtn = Instance.new("TextButton")

local currentReach = 15

ScreenGui.Parent = game.CoreGui
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
MainFrame.Position = UDim2.new(0.5, -100, 0.5, -60)
MainFrame.Size = UDim2.new(0, 200, 0, 150)
MainFrame.Active = true
MainFrame.Draggable = true

Title.Parent = MainFrame
Title.Size = UDim2.new(1, 0, 0, 30)
Title.Text = "ZERO REACH CONTROL"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.BackgroundColor3 = Color3.fromRGB(40, 40, 40)

ReachLabel.Parent = MainFrame
ReachLabel.Position = UDim2.new(0, 0, 0.3, 0)
ReachLabel.Size = UDim2.new(1, 0, 0, 30)
ReachLabel.Text = "Range: " .. currentReach
ReachLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
ReachLabel.BackgroundTransparency = 1

IncreaseBtn.Parent = MainFrame
IncreaseBtn.Position = UDim2.new(0.1, 0, 0.6, 0)
IncreaseBtn.Size = UDim2.new(0.35, 0, 0.3, 0)
IncreaseBtn.Text = "+"
IncreaseBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
IncreaseBtn.TextColor3 = Color3.fromRGB(255, 255, 255)

DecreaseBtn.Parent = MainFrame
DecreaseBtn.Position = UDim2.new(0.55, 0, 0.6, 0)
DecreaseBtn.Size = UDim2.new(0.35, 0, 0.3, 0)
DecreaseBtn.Text = "-"
DecreaseBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
DecreaseBtn.TextColor3 = Color3.fromRGB(255, 255, 255)

local function updateReach()
    ReachLabel.Text = "Range: " .. currentReach
end

IncreaseBtn.MouseButton1Click:Connect(function()
    currentReach = currentReach + 5
    updateReach()
end)

DecreaseBtn.MouseButton1Click:Connect(function()
    if currentReach > 5 then
        currentReach = currentReach - 5
        updateReach()
    end
end)

game:GetService("RunService").RenderStepped:Connect(function()
    for _, v in pairs(game.Workspace:GetChildren()) do
        if v.Name == "Ball" or v.Name == "Football" then
            local lp = game.Players.LocalPlayer
            if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                local mag = (lp.Character.HumanoidRootPart.Position - v.Position).Magnitude
                if mag <= currentReach then
                    firetouchinterest(lp.Character.HumanoidRootPart, v, 0)
                    firetouchinterest(lp.Character.HumanoidRootPart, v, 1)
                end
            end
        end
    end
end)
