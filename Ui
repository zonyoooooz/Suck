local _ReachOptions = Tabs.Gameplay:AddSection('Reach Options')
local _FarmOptions = Tabs.Gameplay:AddSection('Farm Options')
local _BallOptions = Tabs.Gameplay:AddSection('Ball Options')

getgenv().Reach = { Enabled = false, Range = 10 }

_ReachOptions:AddToggle('ReachToggle', {
    Title = 'Enable Reach',
    Default = false,
    Callback = function(state)
        getgenv().Reach.Enabled = state
        while getgenv().Reach.Enabled do
            pcall(function()
                local ball = workspace.TPSSystem.TPS
                local char = game.Players.LocalPlayer.Character
                local leg = char:FindFirstChild("Right Leg") or char:FindFirstChild("RightLowerLeg")
                if (leg.Position - ball.Position).Magnitude <= getgenv().Reach.Range * 2 then
                    firetouchinterest(leg, ball, 0)
                    firetouchinterest(leg, ball, 1)
                end
            end)
            task.wait()
        end
    end
})

_ReachOptions:AddSlider('ReachSlider', {
    Title = 'Range',
    Min = 0, Max = 15, Default = 10, Rounding = 0.1,
    Callback = function(val) getgenv().Reach.Range = val end
})

