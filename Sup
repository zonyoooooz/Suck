function PLeg()
    if game:GetService('Players').LocalPlayer.PlayerGui.Start.Settings.Options.PreferredFoot.Text ~= 'Left' then
        return game:GetService('Players').LocalPlayer.Character:FindFirstChild('Right Leg') or (game:GetService('Players').LocalPlayer.Character:FindFirstChild('RightLowerLeg') or game:GetService('Players').LocalPlayer.Character:FindFirstChild('RightFoot'))
    else
        return game:GetService('Players').LocalPlayer.Character:FindFirstChild('Left Leg') or (game:GetService('Players').LocalPlayer.Character:FindFirstChild('LeftLowerLeg') or game:GetService('Players').LocalPlayer.Character:FindFirstChild('LeftFoot'))
    end
end
function GetGoal(p26)
    if game.Players.LocalPlayer.Team.Name ~= 'Blue' then
        if game.Players.LocalPlayer.Team.Name ~= 'Red' then
            return nil
        end
        if p26 == 'Them' then
            return game:GetService('Workspace').TPSSystem.Part2
        end
        if p26 == 'Me' then
            return game:GetService('Workspace').TPSSystem.Part1
        end
    else
        if p26 == 'Them' then
            return game:GetService('Workspace').TPSSystem.Part1
        end
        if p26 == 'Me' then
            return game:GetService('Workspace').TPSSystem.Part2
