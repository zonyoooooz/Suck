‚Äèlocal turret = script.Parent
‚Äèlocal Players = game:GetService("Players")
‚Äèlocal RunService = game:GetService("RunService")
‚Äèlocal ReplicatedStorage = game:GetService("ReplicatedStorage")

‚Äèlocal turretEvent = Instance.new("RemoteEvent")
‚ÄèturretEvent.Name = "TurretToggleEvent"
‚ÄèturretEvent.Parent = ReplicatedStorage

‚Äèlocal turretEnabled = true
‚ÄèturretEvent.OnServerEvent:Connect(function(player, state)
‚Äè	turretEnabled = state
‚Äèend)

‚Äèlocal RANGE = 150
‚Äèlocal PROJECTILE_SPEED = 220
‚Äèlocal SMOOTHNESS = 0.2
‚Äèlocal FOV_DOT = 0.45
‚Äèlocal FIRE_COOLDOWN = 0.12
‚Äèlocal DAMAGE = 15
‚Äèlocal SPREAD = 0.02

‚Äèlocal lastShot = 0

‚Äèlocal function getPos()
‚Äè	return turret.Position
‚Äèend

‚Äèlocal function getNearestTarget()
‚Äè	local nearest, shortest = nil, RANGE
‚Äè	for _, plr in pairs(Players:GetPlayers()) do
‚Äè		local char = plr.Character
‚Äè		if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") then
‚Äè			local dist = (char.HumanoidRootPart.Position - getPos()).Magnitude
‚Äè			if dist < shortest and char.Humanoid.Health > 0 then
‚Äè				shortest = dist
‚Äè				nearest = char
‚Äè			end
‚Äè		end
‚Äè	end
‚Äè	return nearest
‚Äèend

‚Äèlocal function predictPosition(hrp)
‚Äè	local dist = (hrp.Position - getPos()).Magnitude
‚Äè	local time = dist / PROJECTILE_SPEED
‚Äè	return hrp.Position + (hrp.Velocity * time)
‚Äèend

‚Äèlocal function inFOV(targetPos)
‚Äè	local dir = (targetPos - getPos()).Unit
‚Äè	return turret.CFrame.LookVector:Dot(dir) > FOV_DOT
‚Äèend

‚Äèlocal function canSee(targetPos)
‚Äè	local params = RaycastParams.new()
‚Äè	params.FilterDescendantsInstances = {turret}
‚Äè	params.FilterType = Enum.RaycastFilterType.Blacklist

‚Äè	local result = workspace:Raycast(getPos(), (targetPos - getPos()), params)
‚Äè	if result and result.Instance then
‚Äè		return result.Instance.Parent:FindFirstChild("Humanoid") ~= nil
‚Äè	end
‚Äè	return false
‚Äèend

‚Äèlocal function smoothLook(targetPos)
‚Äè	local goal = CFrame.lookAt(getPos(), targetPos)
‚Äè	turret.CFrame = turret.CFrame:Lerp(goal, SMOOTHNESS)
‚Äèend

‚Äèlocal function shoot(targetPos)
‚Äè	if tick() - lastShot < FIRE_COOLDOWN then return end
‚Äè	lastShot = tick()

‚Äè	local origin = getPos()
‚Äè	local dir = (targetPos - origin).Unit

‚Äè	dir = (dir + Vector3.new(
‚Äè		math.random(-SPREAD, SPREAD),
‚Äè		math.random(-SPREAD, SPREAD),
‚Äè		math.random(-SPREAD, SPREAD)
‚Äè	)).Unit

‚Äè	local params = RaycastParams.new()
‚Äè	params.FilterDescendantsInstances = {turret}
‚Äè	params.FilterType = Enum.RaycastFilterType.Blacklist

‚Äè	local result = workspace:Raycast(origin, dir * RANGE, params)

‚Äè	if result and result.Instance then
‚Äè		local hum = result.Instance.Parent:FindFirstChild("Humanoid")
‚Äè		if hum then
‚Äè			hum:TakeDamage(DAMAGE)
‚Äè		end
‚Äè	end
‚Äèend

‚ÄèRunService.Heartbeat:Connect(function()
‚Äè	if not turretEnabled then return end

‚Äè	local target = getNearestTarget()
‚Äè	if not target then return end

‚Äè	local hrp = target:FindFirstChild("HumanoidRootPart")
‚Äè	if not hrp then return end

‚Äè	local predicted = predictPosition(hrp)

‚Äè	if inFOV(predicted) and canSee(predicted) then
‚Äè		smoothLook(predicted)
‚Äè		shoot(predicted)
‚Äè	end
‚Äèend)

‚Äèlocal button = script.Parent
‚Äèlocal turretEvent = game.ReplicatedStorage:WaitForChild("TurretToggleEvent")

‚Äèlocal enabled = true

‚Äèlocal function update()
‚Äè	button.Text = "Turret AI : " .. (enabled and "ON" or "OFF")
‚Äèend

‚Äèupdate()

‚Äèbutton.MouseButton1Click:Connect(function()
‚Äè	enabled = not enabled
‚Äè	update()
‚Äè	turretEvent:FireServer(enabled)
‚Äèend)
