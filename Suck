local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

local Window = Fluent:CreateWindow({
    Title = "ZERO | ANTI-BAN EDITION",
    SubTitle = "Security Protocol Active",
    TabWidth = 160,
    Size = UDim2.fromOffset(580, 460),
    Acrylic = false,
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.LeftControl
})

local Tabs = {
    Security = Window:AddTab({ Title = "Safe Reach", Icon = "shield" }),
    Settings = Window:AddTab({ Title = "Settings", Icon = "settings" })
}

getgenv().ZonSafe = {
    Enabled = false,
    Range = 7,
    PulseDelay = 0.15,
    UseAntiCheatBypass = true
}

local SecuritySection = Tabs.Security:AddSection("Safe Reach Configuration")

Tabs.Security:AddToggle("SafeMode", {
    Title = "Activate Anti-Ban Reach",
    Default = false,
    Callback = function(v) getgenv().ZonSafe.Enabled = v end
})

Tabs.Security:AddSlider("RangeSlider", {
    Title = "Legit Range",
    Min = 3, Max = 12, Default = 7,
    Rounding = 1,
    Callback = function(v) getgenv().ZonSafe.Range = v end
})

local lastPulse = 0

game:GetService("RunService").Heartbeat:Connect(function()
    if getgenv().ZonSafe.Enabled then
        local currentTime = tick()
        
        if currentTime - lastPulse >= getgenv().ZonSafe.PulseDelay then
            pcall(function()
                local lp = game.Players.LocalPlayer
                local ball = workspace.TPSSystem.TPS
                local root = lp.Character.HumanoidRootPart
                
                local magnitude = (root.Position - ball.Position).Magnitude
                
                if magnitude <= getgenv().ZonSafe.Range then
                    firetouchinterest(root, ball, 0)
                    task.wait(0.02)
                    firetouchinterest(root, ball, 1)
                    
                    lastPulse = currentTime + math.random(0.01, 0.04)
                end
            end)
        end
    end
end)

if getgenv().ZonSafe.UseAntiCheatBypass then
    pcall(function()
        settings().Network.IncomingReplicationLag = 0.05
    end)
end

Window:SelectTab(1)
