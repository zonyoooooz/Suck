local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

local Window = Fluent:CreateWindow({
    Title = "TPS: STREET SOCCER | ZON EDITION",
    SubTitle = "The Future of Free",
    TabWidth = 160,
    Size = UDim2.fromOffset(580, 460),
    Acrylic = false,
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.LeftControl
})

local Tabs = {
    Main = Window:AddTab({ Title = "React & Moss", Icon = "Zap" }),
    Ball = Window:AddTab({ Title = "Ball Mod", Icon = "Circle" }),
    Visuals = Window:AddTab({ Title = "Visuals", Icon = "Eye" })
}

getgenv().Config = {
    ReachEnabled = false,
    ReachSize = 12,
    MossEnabled = false,
    GKReact = false,
    BrutalReact = false,
    BallSize = 2.9
}

local ReactSection = Tabs.Main:AddSection("Main Power")

Tabs.Main:AddToggle("ReachToggle", {
    Title = "Enable Reach (Method 2)",
    Default = false,
    Callback = function(v) getgenv().Config.ReachEnabled = v end
})

Tabs.Main:AddSlider("ReachSlider", {
    Title = "Reach Size",
    Min = 5, Max = 50, Default = 12,
    Rounding = 1,
    Callback = function(v) getgenv().Config.ReachSize = v end
})

Tabs.Main:AddToggle("MossToggle", {
    Title = "Enable Moss & Head Reach",
    Default = false,
    Callback = function(v) getgenv().Config.MossEnabled = v end
})

Tabs.Main:AddToggle("GKToggle", {
    Title = "GK React (Goalkeeper)",
    Default = false,
    Callback = function(v) getgenv().Config.GKReact = v end
})

local BallSection = Tabs.Ball:AddSection("Ball Modifications")

Tabs.Ball:AddInput("BSize", {
    Title = "Ball Size",
    Default = "2.9",
    Callback = function(v) getgenv().Config.BallSize = tonumber(v) or 2.9 end
})

game:GetService("RunService").RenderStepped:Connect(function()
    pcall(function()
        local lp = game.Players.LocalPlayer
        local char = lp.Character
        local ball = workspace.TPSSystem.TPS
        
        if char and ball then
            local root = char.HumanoidRootPart
            local dist = (root.Position - ball.Position).Magnitude
            
            if getgenv().Config.ReachEnabled and dist <= getgenv().Config.ReachSize then
                firetouchinterest(root, ball, 0)
                firetouchinterest(root, ball, 1)
            end
            
            if getgenv().Config.MossEnabled then
                char.Head.CFrame = CFrame.new(char.Head.Position, ball.Position)
            end
            
            if ball:IsA("BasePart") then
                ball.Size = Vector3.new(getgenv().Config.BallSize, getgenv().Config.BallSize, getgenv().Config.BallSize)
            end
        end
    end)
end)

Window:SelectTab(1)
